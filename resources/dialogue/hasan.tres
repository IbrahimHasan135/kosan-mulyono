[sub_resource type="Resource" id="Resource_h1"]
script = ExtResource("2_line")
speaker_id = "npc_hasan"
speaker_display_name = "Hasan"
text = "Eh, lo anak baru ya? Gua Hasan, kamar sebelah."

[sub_resource type="Resource" id="Resource_h2"]
script = ExtResource("2_line")
speaker_id = "player"
speaker_display_name = "Raka"
text = "Oh iya, gua Raka, baru pindah kos hari ini."

[sub_resource type="Resource" id="Resource_h3"]
script = ExtResource("2_line")
speaker_id = "npc_hasan"
speaker_display_name = "Hasan"
text = "Selamat datang di kos horor, hati-hati kesambet — becanda doang kok... kayaknya."


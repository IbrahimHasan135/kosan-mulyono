[sub_resource type="Resource" id="Resource_b1"]
script = ExtResource("2_line")
speaker_id = "npc_buyuni"
speaker_display_name = "Bu Yuni"
text = "Selamat datang di kos saya, Nak. Maaf kalau bau dupa, ini buat menenangkan... almarhum suami saya."

[sub_resource type="Resource" id="Resource_b2"]
script = ExtResource("2_line")
speaker_id = "player"
speaker_display_name = "Raka"
text = "Gak apa-apa, Bu. Permisi, saya Raka, kamar No. 7."

[sub_resource type="Resource" id="Resource_b3"]
script = ExtResource("2_line")
speaker_id = "npc_buyuni"
speaker_display_name = "Bu Yuni"
text = "Jangan ganggu ritual saya kalau lagi jalan ya, Nak. Ini penting buat kos ini."

